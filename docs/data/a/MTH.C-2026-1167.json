  "statement": {
    "decl_names": [
      "WMSpec.matched_invariance_iff"
    ],
    "module": "WMSpec.MatchedObjective",
    "pretty": "∀ {Θ : Type u_1} {X : Type u_2} {k : ℕ} {ι : Type u_4} {Lpred : Θ → X → List ι → ℕ} {G : Fin k → X → ℝ}\n  {lam : Fin k → ℝ} {g : X → X},\n  (∀ (θ : Θ) (x : X) (I₁ I₂ : List ι), Lpred θ x (I₁ ++ I₂) = Lpred θ x I₁ + Lpred θ x I₂) →\n    ∀ (θ₀ : Θ),\n      WMSpec.ObjectiveInvariant (WMSpec.matchedObjective Lpred G lam) g ↔\n        WMSpec.ObjectiveInvariant Lpred g ∧ ∀ (x : X), ∑ j, lam j * G j (g x) = ∑ j, lam j * G j x"
  },

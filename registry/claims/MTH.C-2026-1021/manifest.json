    "module": "WMSpec.NonIdentifiability.KernelLumpability",
    "pretty": "∀ {S : Type u_1} (r : Setoid S) (P : S → PMF S),\n  (∃ Q, ∀ (s : S), Q ⟦s⟧ = PMF.map (Quotient.mk r) (P s)) ↔\n    ∀ (s₁ s₂ : S), r s₁ s₂ → PMF.map (Quotient.mk r) (P s₁) = PMF.map (Quotient.mk r) (P s₂)"
  },

  "module": "Eidometry.Thesis",
  "pretty": "∀ (Q : WMSpec.QubitSystem) (t : ℝ), Real.sin (WMSpec.QubitSystem.ω Q * t) ≠ 0 → ∀ (ψ χ : ℂ × ℂ), WMSpec.QubitSystem.pop 0 ψ + WMSpec.QubitSystem.pop 1 ψ = 1 → WMSpec.QubitSystem.pop 0 χ + WMSpec.QubitSystem.pop 1 χ = 1 → ((TLT.NonIdentifiability.bisimilarity (fun x => WMSpec.QubitSystem.posExp Q) (TLT.NonIdentifiability.pureKernel (WMSpec.QubitSystem.U Q t))) ψ χ ↔ ∃ θ, χ = WMSpec.QubitSystem.phase θ ψ ∨ χ = WMSpec.QubitSystem.phase θ (WMSpec.QubitSystem.swapConj ψ))"
 },
